# Solana Agent MCP — Environment Variables
# Copy to .env and fill in your keys

# Helius API keys (comma-separated, get free keys at https://dev.helius.xyz)
HELIUS_API_KEYS=your-key-1,your-key-2

# Server port (default: 8791)
SOLANA_MCP_PORT=8791

# Private key for live transactions (JSON array of 64 bytes — Phantom format)
# Without this, only read-only tools + devnet airdrops are available
PRIVATE_KEY=[0,0,0,...]
